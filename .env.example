# ── LiveKit (Signaling + WebRTC SFU) ────────────────────────────
# Used by apps/web API route to sign JWT tokens (server-side only)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Used by apps/web client to connect to LiveKit SFU
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ── DICOM Express Server ─────────────────────────────────────────
# URL of the Express backend accessed by the browser
NEXT_PUBLIC_DICOM_SERVER_URL=http://localhost:3001

# Security: CORS origin restriction on the Express server (must match Next.js dev URL)
FRONTEND_URL=http://localhost:3000

# ── Server Ports (optional overrides) ───────────────────────────
PORT=3001
NODE_ENV=development
